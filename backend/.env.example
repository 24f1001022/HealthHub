# Copy to .env for local development. Never commit .env.

SECRET_KEY=change-me-local-dev
FLASK_ENV=development
USE_CELERY=false
CRON_SECRET=local-cron-secret

DATABASE_URL=sqlite:///hospital.db
# Use "Redis URL" from Upstash (starts with rediss://) — NOT the REST https URL
REDIS_URL=redis://localhost:6379/0

PUBLIC_BASE_URL=http://localhost:5000
FRONTEND_URL=http://localhost:5173

# Gmail: enable 2FA, then create an App Password at https://myaccount.google.com/apppasswords
MAIL_SERVER=smtp.gmail.com
MAIL_PORT=587
MAIL_USE_TLS=True
MAIL_USERNAME=your.email@gmail.com
MAIL_PASSWORD=your-16-char-app-password
